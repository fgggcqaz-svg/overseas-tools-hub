# RSS Fetcher Configuration

# RSS feed URLs (comma-separated or JSON array)
# Examples:
# RSS_SOURCES=https://appsumo.com/tools/feed/,https://another-source.com/feed/
RSS_SOURCES=

# Optional: Max items per source (default: 10)
FETCH_LIMIT=10

# Optional: User-Agent for requests
USER_AGENT=Mozilla/5.0 (compatible; OpenWork/1.0)
