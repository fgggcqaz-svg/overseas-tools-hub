# Publisher Configuration (Vercel + GitHub)

# GitHub Configuration
# Get token from: https://github.com/settings/tokens/new
# Required scope: repo (full control of private repositories)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=username/your-site-repo
GITHUB_BRANCH=main

# Content Configuration
# Where to store markdown files
CONTENT_DIR=content/tools
# Where to store JSON index
DATA_DIR=data

# Site Configuration
SITE_URL=https://your-site.vercel.app

# Optional: Auto-commit and push (default: true)
AUTO_PUSH=true
